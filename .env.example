# MLOps Pipeline Debugger Environment Variables

# Required: Hugging Face API token for authentication
HF_TOKEN=add your apii token here


# Optional: API base URL (defaults to HF router)
API_BASE_URL=https://router.huggingface.co/v1

# Optional: Model name (defaults to Qwen/Qwen2.5-72B-Instruct)
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=7860

# Development
DEBUG=false
LOG_LEVEL=INFO
